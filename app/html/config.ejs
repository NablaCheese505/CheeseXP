                <p class="details"><%= t('dashboard.Allows', {}, lang) %><b><%= t('dashboard.anyone', {}, lang) %></b><%= t('dashboard.torunmoderatorcommandsegaddxporcleareveniftheydonthavetheManageServerpermissionUsefulifyouwanttosetcustomslashcommandpermissionsfortheserver', {}, lang) %></p>
                <label class="slider" style="margin-top: 5px">
                    <input db="manualPerms" savename="db" tabindex="0" type="checkbox"/>
                    <span class="sliderspan"></span>
                </label>
            </div>
            <div class="settingBox box" style="height: 171px">
                <h2><%= t('dashboard.MaximumLevel', {}, lang) %></h2>
                <p class="details"><%= t('dashboard.ThehighestlevelthatmemberscanreachTheycanstillgainXPpastthis', {}, lang) %><br/><%= t('dashboard.TodisableXPgainafterreachingthemaxlevelusearewardrolewitha0xmultiplier', {}, lang) %></p>
                <div class="centerflex spacedflex" style="margin-top: 10px">
                    <input db="maxLevel" default="1000" max="1000" min="0" placeholder="1000" savename="db" style="width: 80px" type="number"/>
                </div>
            </div>
            <div class="settingBox box" style="height: 145px">
                <h2><%= t('dashboard.CustomrankEmbedColor', {}, lang) %></h2>
                <p class="details"><%= t('dashboard.Changestheembedcolorwhenusingrank', {}, lang) %><br/><%= t('dashboard.Usesthemembersroleprofilecolorbydefault', {}, lang) %></p>
                <div class="centerflex" style="height: 45px">
                    <label class="slider" style="margin-top: 5px">
                        <input id="useCustomEmbedColRank" onchange="$('#customEmbedColRankConfig').toggle($(this).prop('checked')); checkUnsavedChanges()" tabindex="0" type="checkbox"/>
                        <span class="sliderspan"></span>
                    </label>
                    <div class="centerflex" id="customEmbedColRankConfig" style="display: none">
                        <input class="colorInput" for="customEmbedColRank" maxlength="7" placeholder="#00ff80" style="width: 100px; margin-left: 20px" value="#00ff80"/>
                        <div class="colInputPreview" for="customEmbedColRank" style="margin-left: 10px" tabindex="0"></div>
                        <input class="hiddenColInput previewColorInput" db="rankCard.embedColor" id="customEmbedColRank" savename="db" type="color" useif="useCustomEmbedColRank" value="#00ff80"/>
                    </div>
                </div>
            </div>
            <div class="settingBox box" style="height: 145px">
                <h2><%= t('dashboard.CustomtopEmbedColor', {}, lang) %></h2>
                <p class="details"><%= t('dashboard.Changestheembedcolorwhenusingtop', {}, lang) %><br/><%= t('dashboard.UsesPolarisgreenbydefault', {}, lang) %></p>
                <div class="centerflex" style="height: 45px">
                    <label class="slider" style="margin-top: 5px">
                        <input id="useCustomEmbedColTop" onchange="$('#customEmbedColTopConfig').toggle($(this).prop('checked')); checkUnsavedChanges()" tabindex="0" type="checkbox"/>
                        <span class="sliderspan"></span>
                    </label>
                    <div class="centerflex" id="customEmbedColTopConfig" style="display: none">
                        <input class="colorInput" for="customEmbedColTop" maxlength="7" placeholder="#00ff80" style="width: 100px; margin-left: 20px" value="#00ff80"/>
                        <div class="colInputPreview" for="customEmbedColTop" style="margin-left: 10px" tabindex="0"></div>
                        <input class="hiddenColInput previewColorInput" db="leaderboard.embedColor" id="customEmbedColTop" savename="db" type="color" useif="useCustomEmbedColTop" value="#00ff80"/>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
