<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    
    <title><%= t('config_page.global.page_title', {}, lang) %></title>
    <meta name="robots" content="noindex"> 
    <meta name="theme-color" content="#00ff80">

    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= siteURL %>/settings">
    <meta property="og:title" content="<%= t('config_page.global.page_title', {}, lang) %>">
    <meta property="og:description" content="<%= t('home_page.description', {}, lang) %>">
    <meta property="og:image" content="<%= siteURL %>/assets/cheese.png">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= t('config_page.global.page_title', {}, lang) %>">
    <meta name="twitter:description" content="<%= t('home_page.description', {}, lang) %>">
    <meta name="twitter:image" content="<%= siteURL %>/assets/cheese.png">
    <meta property="og:image:width" content="1080">
    <meta property="og:image:height" content="1080">
    <meta property="og:image:type" content="image/png">
    
    <link href="/css/polaris.css?v=3" rel="stylesheet" type="text/css"/>
    <link href="/assets/polaris.svg" rel="icon"/>
</head>
<body>
    <h2 class="middleflex" id="loading" style="margin-top: 75px; width: 100%; position: absolute;"><%= t('config_page.global.loading', {}, lang) %></h2>
    <div id="everything" style="display: none;">
        <div id="sidebar">
            <div tabindex="0" category="server" class="category" title="<%= t('config_page.sidebar.home_desc', {}, lang) %>">
                <img class="serverIcon" style="border-radius: 420px"> <p><%= t('config_page.sidebar.home', {}, lang) %></p>
            </div>
            <div tabindex="0" category="xp" class="category" title="<%= t('config_page.sidebar.xp_desc', {}, lang) %>">
                <i data-lucide="sparkles"></i>
                <p><%= t('config_page.sidebar.xp', {}, lang) %></p>
            </div>
            <div tabindex="0" category="rewardroles" class="category" title="<%= t('config_page.sidebar.rewards_desc', {}, lang) %>">
                <i data-lucide="gift"></i>
                <p><%= t('config_page.sidebar.rewards', {}, lang) %></p>
            </div>
            <div tabindex="0" category="levelup" class="category" title="<%= t('config_page.sidebar.levelup_desc', {}, lang) %>">
                <i data-lucide="message-square-plus"></i>
                <p><%= t('config_page.sidebar.levelup', {}, lang) %></p>
            </div>
            <div tabindex="0" category="multipliers" class="category" title="<%= t('config_page.sidebar.multipliers_desc', {}, lang) %>">
                <i data-lucide="zap"></i>
                <p><%= t('config_page.sidebar.multipliers', {}, lang) %></p>
            </div>
            <div tabindex="0" category="rankcard" class="category" title="<%= t('config_page.sidebar.rankcard_desc', {}, lang) %>">
                <i data-lucide="id-card"></i>
                <p><%= t('config_page.sidebar.rankcard', {}, lang) %></p>
            </div>
            <div tabindex="0" category="leaderboard" class="category" title="<%= t('config_page.sidebar.leaderboard_desc', {}, lang) %>">
                <i data-lucide="bar-chart-2"></i>
                <p><%= t('config_page.sidebar.leaderboard', {}, lang) %></p>
            </div>
            <div tabindex="0" category="data" class="category" title="<%= t('config_page.sidebar.data_desc', {}, lang) %>">
                <i data-lucide="database"></i>
                <p><%= t('config_page.sidebar.data', {}, lang) %></p>
            </div>
            <div tabindex="0" category="advanced" class="category" title="<%= t('config_page.sidebar.advanced_desc', {}, lang) %>">
                <i data-lucide="settings"></i>
                <p><%= t('config_page.sidebar.advanced', {}, lang) %></p>
            </div>
        </div>
        
        <div id="unsavedWarning">
            <div class="unsavedBox">
                <p><%= t('config_page.global.unsaved_text', {}, lang) %></p>
                <button id="saveChanges" style="background-color: var(--emojigreen)"><%= t('config_page.global.btn_save', {}, lang) %></button>
            </div>
        </div>

        <div class="configboxes" id="serverInfo" style="display: none" tab="server">
            <div class="settingBox box fulllength" style="padding: 15px 20px; position: relative">
                <div class="centerflex">
                    <img class="serverIcon" style="border-radius: 420px; height: 75px"/>
                    <div style="margin-left: 18px; overflow: hidden;">
                        <h1 class="serverName" style="text-overflow: ellipsis; overflow: hidden; white-space: nowrap; margin-bottom: 0px"></h1>
                        <p class="serverMembers" style="margin-top: 0px"></p>
                    </div>
                </div>
                <div class="middleflex" style="position: absolute; top: 0px; right: 30px; height: 100%">
                    <a href="/servers" tabindex="-1">
                        <button style="font-size: 24px; height: 50px; width: 200px; margin-right: 25px; background-color: var(--emojiblue)"><%= t('dashboard.ChangeServer', {}, lang) %></button>
                    </a>
                    <a class="leaderboardLink" id="mainlbbutton" tabindex="-1" target="_blank">
                        <button style="font-size: 24px; height: 50px; width: 200px; background-color: var(--emojipurple)"><%= t('dashboard.Leaderboard', {}, lang) %></button>
                    </a>
                </div>
            </div>
            <div class="settingBox box categoryBox canfocus" tabindex="0">
                <div class="centerflex">
                    <div cat="icon" class="icon-container"></div> 
                    <div style="overflow: hidden">
                        <h2 cat="name"></h2>
                        <p cat="info" class="details" style="height: 56px"></p>
                        <p cat="extra" style="white-space: nowrap"></p>
                    </div>
                </div>
            </div>
        </div>

        <div class="configboxes" style="display: none" tab="xp">
            <div class="settingBox box fulllength">
                <h1><%= t('dashboard.XPGain', {}, lang) %></h1>
                <p><%= t('dashboard.WheneveramembersendsamessagetheygainarandomamountofXPexperiencepointsandtriggerashortcooldownWhenthecooldownfinishestheycangainmoreXPCongratulationsYoujustlearnedhowXPbotswork', {}, lang) %></p>
                <h2><%= t('dashboard.EnableXP', {}, lang) %></h2>
                <p class="details"><%= t('dashboard.WhenenabledmemberswillbeabletogainXPThisisthewholepointofthebot', {}, lang) %></p>
                <label class="slider" style="margin-top: 5px">
                    <input db="enabled" id="enableLevelUp" savename="db" type="checkbox"/>
                    <span class="sliderspan"></span>
                </label>
            </div>
            <div class="settingBox box fulllength">
                <h1><%= t('dashboard.BasicSettings', {}, lang) %></h1>
                <p><%= t('dashboard.CustomizetheamountofXPearnedaswellashowoftenitcanbegainedEasyenough', {}, lang) %></p>
                <div class="simpleflex">
                    <div class="sideoption">
                        <h2><%= t('dashboard.XPpermessage', {}, lang) %></h2>
                        <p class="details"><%= t('dashboard.Amountisrandomlypickedbetweentheminandmaxvalue', {}, lang) %></p>
                        <div class="field">
                            <div class="centerflex spacedflex">
                                <p><%= t('dashboard.Between', {}, lang) %></p>
                                <input db="gain.min" default="50" id="num_min" max="5000" min="0" savename="db" style="width: 75px" type="number" updatecurve="true"/>
                                <p><%= t('dashboard.and', {}, lang) %></p>
                                <input db="gain.max" default="50" id="num_max" max="5000" min="0" savename="db" style="width: 75px" type="number" updatecurve="true"/>
                            </div>
                        </div>
                    </div>
                    <div class="sideoptions">
                        <h2><%= t('dashboard.Cooldown', {}, lang) %></h2>
                        <p class="details"><%= t('dashboard.MembersmustwaitthismanysecondsbeforetheycangainXPagain', {}, lang) %></p>
                        <div class="field">
                            <div class="centerflex spacedflex">
                                <input db="gain.time" decimals="4" default="60" id="num_time" max="31536000" min="0" savename="db" style="width: 100px" type="number" updatecurve="true"/>
                                <p><%= t('dashboard.seconds', {}, lang) %></p>
                                <p id="cooldownunit" style="opacity: 70%; display: none"></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="settingBox box fulllength">
                <h1><%= t('dashboard.VoiceXPGain', {}, lang) %></h1>
                <p><%= t('dashboard.VoiceXPGainDesc', {}, lang) %></p>
                <h2><%= t('dashboard.EnableVoiceXP', {}, lang) %></h2>
                <p class="details"><%= t('dashboard.EnableVoiceXPDesc', {}, lang) %></p>
                <label class="slider" style="margin-top: 5px">
                    <input db="enabledVoiceXp" savename="db" type="checkbox"/>
                    <span class="sliderspan"></span>
                </label>
            </div>
            
            <div class="settingBox box fulllength">
                <h1><%= t('dashboard.VoiceXPSettings', {}, lang) %></h1>
                <p><%= t('dashboard.VoiceXPSettingsDesc', {}, lang) %></p>
                <div class="simpleflex">
                    <div class="sideoption">
                        <h2><%= t('dashboard.VoiceXPMultiplier', {}, lang) %></h2>
                        <p class="details"><%= t('dashboard.VoiceXPMultiplierDesc', {}, lang) %></p>
                        <div class="field">
                            <div class="centerflex spacedflex">
                                <input id="vcMultiplier" db="voice.multiplier" savename="db" default="1" max="10" min="0" step="0.1" style="width: 75px" type="number"/>
                            </div>
                        </div>
                    </div>
                    <div class="sideoptions">
                        <h2><%= t('dashboard.HoursLimit', {}, lang) %></h2>
                        <p class="details"><%= t('dashboard.HoursLimitDesc', {}, lang) %></p>
                        <div class="field">
                            <div class="centerflex spacedflex">
                                <input id="hoursLimit" db="voice.hoursLimit" savename="db" default="0" max="24" min="0" step="0.5" style="width: 75px" type="number"/>
                                <p><%= t('dashboard.hours', {}, lang) %></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="settingBox box fulllength">
                <h1><%= t('dashboard.LevelScaling', {}, lang) %></h1>
                <p><%= t('dashboard.BygainingenoughXPmemberscanlevelupandearnspecialrolesorbraggingrightsTheamountofXPrequiredscaleswitheachlevelearlylevelsonlyneedacouplethousandpointsbutlaterlevelsneedmillions', {}, lang) %></p>
                <p><%= t('dashboard.YoucanadjustthelevelscalingtochangehowmanymorepointsarerequiredwitheachlevelAsmallercurvemakesiteasiertolevelupandalargercurvemakesitmuchmoredifficult', {}, lang) %></p>
                <div class="simpleflex">
                    <div class="sideoption">
                        <h2 id="curveStuff"><%= t('dashboard.Curveformula', {}, lang) %></h2>
                        <p class="details"><%= t('dashboard.CubicfunctionthatdetermineshowmuchXPisneededforeachlevel', {}, lang) %></p>
                        <div class="field">
                            <div class="centerflex curvefield">
                                <input db="curve.3" decimals="10" default="0" id="num_curve3" max="100" min="0" savename="db" style="width: 65px" type="number" updatecurve="true"/>
                                <p>x<sup>3</sup>     + </p>
                                <input db="curve.2" decimals="10" default="0" id="num_curve2" max="10000" min="0" savename="db" style="width: 65px" type="number" updatecurve="true"/>
                                <p>x<sup>2</sup>     + </p>
                                <input db="curve.1" decimals="10" default="0" id="num_curve1" max="100000" min="0" savename="db" style="width: 65px" type="number" updatecurve="true"/>
                                <p>x</p>
                            </div>
                        </div>
                        <p><%= t('dashboard.Difficultyrating', {}, lang) %><b id="scaleDifficulty" style="color: aqua"></b></p>
                    </div>
                    <div class="sideoption">
                        <h2><%= t('dashboard.Rounding', {}, lang) %></h2>
                        <p class="details"><%= t('dashboard.RoundstherequiredXPtoanicernumbereg791XP800XP', {}, lang) %></p>
                        <div class="centerflex spacedflex">
                            <p><%= t('dashboard.Roundtonearest', {}, lang) %></p>
                            <input db="rounding" default="1" id="num_round" max="1000" min="1" savename="db" style="width: 80px" type="number" updatecurve="true"/>
                        </div>
                    </div>
                </div>
                <div style="display: flex; flex-direction: column; gap: 30px; width: 100%;">
                    <div>
                        <h2 style="margin-bottom: 12px"><%= t('dashboard.Preview', {}, lang) %></h2>
                        <div class="simpleflex flexTable" id="curvePreview"></div>
                        <button id="showMoreCurveInfo" style="margin-top: 16px; width: 140px"><%= t('dashboard.Moreinfo', {}, lang) %></button>
                    </div>
                    <div>
                    <div class="desmos" id="xpGraph"></div>
                        <p class="details" id="desmosJumpscare" style="font-size: 10px; opacity: 25%"><%= t('dashboard.desmosjumpscare', {}, lang) %></p>
                    </div>
                </div>
                <div id="fullPreviewSection" style="display: none">
                    <h2 style="margin-bottom: 12px"><%= t('dashboard.FullTable', {}, lang) %></h2>
                    <div class="simpleflex flexTable" id="fullCurvePreview"></div>
                    <button onclick="$('#fullPreviewSection').hide()" style="margin-top: 16px; width: 140px; background-color: var(--emojipurple)"><%= t('dashboard.Hide', {}, lang) %></button>
                </div>
            </div>
            <div class="settingBox box fulllength">
                <h1><%= t('dashboard.Presets', {}, lang) %></h1>
                <p><%= t('dashboard.BalancingishardHeressomepresetstopickfrom', {}, lang) %></p>
                <div class="simpleflex">
                    <div style="width: 750px">
                        <h2><%= t('dashboard.Viewpreset', {}, lang) %></h2>
                        <p class="details"><%= t('dashboard.Nosettingswillbechangeduntilyouclickapply', {}, lang) %></p>
                        <select id="curvePresets"></select>
                        <p id="presetDesc" style="margin-bottom: 8px; font-style: italic;"><%= t('dashboard.Curvedescription', {}, lang) %></p>
                        <div class="curveInfo">
                            <p>- <b><%= t('dashboard.Curve', {}, lang) %></b> <span id="presetCurve"></span></p>
                            <p>- <b><%= t('dashboard.Difficulty', {}, lang) %></b> <span id="presetDifficulty"></span></p>
                            <p>- <b><%= t('dashboard.Rounding', {}, lang) %></b> <span id="presetRound"></span></p>
                            <p>- <b><%= t('dashboard.XPpermessage', {}, lang) %></b> <span id="presetXP"></span></p>
                        </div>
                        <button id="applyPreset" style="margin-top: 12px;"><%= t('dashboard.ApplyPreset', {}, lang) %></button>
                    </div>
                </div>
            </div>
        </div>

        <div class="configboxes" style="display: none" tab="rewardroles">
            <div class="settingBox box fulllength">
                <h1><%= t('dashboard.RewardRoles', {}, lang) %></h1>
                <p style="margin-bottom: 3px"><%= t('dashboard.AutomaticallygiverolestomemberswhentheyreachcertainlevelsForfree', {}, lang) %></p>
                <p class="details"><%= t('dashboard.ImagineifItriedtocapitalizeoffacoupleextralinesofcodehahathatwouldbeabsolutelycrazy', {}, lang) %></p>
                <h2><%= t('dashboard.Addrole', {}, lang) %></h2>
                <div class="centerflex spacedflex" style="margin-top:10px">
                    <p><%= t('dashboard.Reward', {}, lang) %></p>
                    <select id="rewardRoleSelect"></select>
                    <p><%= t('dashboard.atlevel', {}, lang) %></p>
                    <input id="rewardLevel" max="1000" min="1" style="width: 90px" type="number"/>
                </div>
                <div class="centerflex spacedflex">
                    <p><%= t('dashboard.Removethisrolewhenahigherroleisobtained', {}, lang) %></p>
                    <label class="slider" style="margin-top: 5px">
                        <input checked="" id="rewardKeep" type="checkbox"/>
                        <span class="sliderspan"></span>
                    </label>
                </div>
                <div class="centerflex spacedflex excludeMode">
                    <p><%= t('dashboard.AdvancedExcludethisrolewhensyncingroles', {}, lang) %></p>
                    <label class="slider" style="margin-top: 5px">
                        <input id="rewardExclude" type="checkbox"/>
                        <span class="sliderspan"></span>
                    </label>
                </div>
                <button id="addRewardRole" style="margin-top: 10px"><%= t('dashboard.Add', {}, lang) %></button>
                <h2 style="margin-top: 50px; margin-bottom: 15px"><%= t('dashboard.Currentrewards', {}, lang) %><span id="rewardCount">0</span>)</h2>
                <div class="simpleflex flexTable" id="rewards"></div>
            </div>
            <div class="settingBox box fulllength">
                <h1><%= t('dashboard.RewardSyncing', {}, lang) %></h1>
                <p><%= t('dashboard.BydefaultthebotwillautomaticallysynclevelrolesbyaddingmissingonesandremovingincorrectonesFeelfreetotweakthisbehaviouralittle', {}, lang) %></p>
                <div class="simpleflex">
                    <div class="sideoption">
                        <h2><%= t('dashboard.Automaticsyncing', {}, lang) %></h2>
                        <p class="details"><%= t('dashboard.Choosewhenthebotshouldautomaticallysynclevelroles', {}, lang) %></p>
                        <select db="rewardSyncing.sync" savename="db">
                            <option value="level"><%= t('dashboard.Onlevelup', {}, lang) %></option>
                            <option value="xp"><%= t('dashboard.OnXPgainslower', {}, lang) %></option>
                            <option value="never"><%= t('dashboard.Never', {}, lang) %></option>
                        </select>
                    </div>
                    <div class="sideoptions">
                        <h2><%= t('dashboard.Manualsyncing', {}, lang) %></h2>
                        <p class="details"><%= t('dashboard.Ifmembersshouldbeabletomanuallysynctheirroleswhenevertheywant', {}, lang) %></p>
                        <label class="slider" style="margin-top: 5px">
                            <input db="rewardSyncing.noManual" invert="true" savename="db" tabindex="0" type="checkbox"/>
                            <span class="sliderspan"></span>
                        </label>
                    </div>
                </div>
                <div class="simpleflex" style="margin-top: 40px">
                    <div class="sideoption">
                        <h2><%= t('dashboard.Showsyncwarning', {}, lang) %></h2>
                        <p class="details"><%= t('dashboard.Displaysawarningmessageinrankifamembersrolesarentsyncedproperly', {}, lang) %></p>
                        <label class="slider" style="margin-top: 5px">
                            <input db="rewardSyncing.noWarning" invert="true" savename="db" tabindex="0" type="checkbox"/>
                            <span class="sliderspan"></span>
                        </label>
                    </div>
                    <div class="sideoptions">
                        <h2><%= t('dashboard.AdvancedExcluderoles', {}, lang) %></h2>
                        <p class="details"><%= t('dashboard.Preventcertainrolesfrombeingreaddedorremovedwhensyncing', {}, lang) %></p>
                        <label class="slider" style="margin-top: 5px">
                            <input id="excludeRewardToggle" tabindex="0" type="checkbox"/>
                            <span class="sliderspan"></span>
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <div class="configboxes" style="display: none" tab="levelup">
            <div class="settingBox box fulllength">
                <h1><%= t('dashboard.Levelupmessage', {}, lang) %></h1>
                <p><%= t('dashboard.SendanautomaticmessageinthechatwhenamemberlevelsupHowfun', {}, lang) %></p>
                <h2><%= t('dashboard.Enablemessage', {}, lang) %></h2>
                <p class="details"><%= t('dashboard.WhenenabledamessageorDMwillbesentwheneveranyonelevelsup', {}, lang) %></p>
                <label class="slider" style="margin-top: 5px">
                    <input db="levelUp.enabled" onchange="$('.ifmessageenabled').toggle($(this).prop('checked'))" savename="db" type="checkbox"/>
                    <span class="sliderspan"></span>
                </label>
            </div>
            <div class="settingBreak"></div>
            <div class="settingBox box fulllength ifmessageenabled">
                <div id="regularMessage">
                    <h1><%= t('dashboard.Message', {}, lang) %></h1>
                    <p><%= t('dashboard.Themessagetosenduponlevellingup', {}, lang) %></p>
                    <textarea class="lvlTextbox" id="lvlUpMessage" placeholder="(no message)" savename="levelUp.message" style="width: 800px"></textarea>
                </div>
                <div id="embedMessage">
                    <h1><%= t('dashboard.Embed', {}, lang) %></h1>
                    <p><%= t('dashboard.Theembeddedmessagetosenduponlevellingup', {}, lang) %></p>
                    <p><b><%= t('dashboard.Step1', {}, lang) %></b> <a href="https://discohook.org/?" target="_blank"><%= t('dashboard.Generateanembedhere', {}, lang) %></a></p>
                    <p><b><%= t('dashboard.Step2', {}, lang) %></b><%= t('dashboard.OpentheJSONdatabypressingJSONDataEditoratthebottomofthesite', {}, lang) %></p>
                    <p><b><%= t('dashboard.Step3', {}, lang) %></b><%= t('dashboard.Copythetextandpasteitintheboxbelow', {}, lang) %></p>
                    <p class="details" style="margin-bottom: 15px"><%= t('dashboard.AllvariablesegUSERNAMEstillworkinembeds', {}, lang) %></p>
                    <textarea class="lvlTextbox codeArea" id="lvlUpEmbed" placeholder="(no embed)" savename="levelUp.message" style="width: 800px"></textarea>
                    <p class="red" id="invalidLevelUpEmbed" style="display: none"><b><%= t('dashboard.Warning', {}, lang) %></b><%= t('dashboard.InvalidembedJSONdataThisembedwillnotwork', {}, lang) %></p>
                </div>
                <div class="simpleflex">
                    <div class="sideoption">
                        <h2><%= t('dashboard.Variables', {}, lang) %></h2>
                        <p class="details"><%= t('dashboard.Spiceupyourmessagewithdynamicvariables', {}, lang) %></p>
                        <div class="varList" id="lvlUpMessageVariables">
                            <select>
                                <option disabled="" selected="" value="x"><%= t('dashboard.XP', {}, lang) %></option>
                                <option value="[[LEVEL]]"><%= t('dashboard.Leveleg10', {}, lang) %></option>
                                <option value="[[OLD_LEVEL]]"><%= t('dashboard.Previousleveleg9', {}, lang) %></option>
                                <option value="[[XP]]"><%= t('dashboard.XPeg10000', {}, lang) %></option>
                                <option value="[[NEXT_LEVEL]]"><%= t('dashboard.Nextleveleg11', {}, lang) %></option>
                                <option value="[[NEXT_XP]]"><%= t('dashboard.XPtonextleveleg1000', {}, lang) %></option>
                            </select>
                            <select>
                                <option disabled="" selected="" value="x"><%= t('dashboard.Member', {}, lang) %></option>
                                <option value="[[@]]"><%= t('dashboard.mentionegPolaris', {}, lang) %></option>
                                <option value="[[DISPLAYNAME]]"><%= t('dashboard.DisplayNameegPolaris', {}, lang) %></option>
                                <option value="[[USERNAME]]"><%= t('dashboard.Usernameegpolaris', {}, lang) %></option>
                                <option value="[[ID]]"><%= t('dashboard.IDeg98341916', {}, lang) %></option>
                                <option value="[[NICKNAME]]"><%= t('dashboard.Nickname', {}, lang) %></option>
                                <option value="[[AVATAR]]"><%= t('dashboard.AvatarURL', {}, lang) %></option>
                            </select>
                            <select>
                                <option disabled="" selected="" value="x"><%= t('dashboard.Server', {}, lang) %></option>
                                <option value="[[SERVER]]"><%= t('dashboard.Servername', {}, lang) %></option>
                                <option value="[[SERVER_ICON]]"><%= t('dashboard.ServericonURL', {}, lang) %></option>
                                <option value="[[SERVER_ID]]"><%= t('dashboard.ServerID', {}, lang) %></option>
                                <option value="[[CHANNEL]]"><%= t('dashboard.Channeltagegchannel', {}, lang) %></option>
                                <option value="[[CHANNEL_NAME]]"><%= t('dashboard.Channelnameegchannel', {}, lang) %></option>
                                <option value="[[CHANNEL_ID]]"><%= t('dashboard.ChannelID', {}, lang) %></option>
                            </select>
                            <select>
                                <option disabled="" selected="" value="x"><%= t('dashboard.Advanced', {}, lang) %></option>
                                <%= t('dashboard.optionvalueDISCRIMAccountDiscriminatoreg6880option', {}, lang) %>
                                <option value="[[LEVEL]][[NTH]]"><%= t('dashboard.Nth1st2nd3rdetc', {}, lang) %></option>
                                <option value="&lt;t:[[TIMESTAMP]]&gt;"><%= t('dashboard.Timestamp', {}, lang) %></option>
                                <option value="[[EMBEDTIMESTAMP]]"><%= t('dashboard.EmbedTimestamp', {}, lang) %></option>
